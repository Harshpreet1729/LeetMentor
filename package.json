{
  "name": "leetcode-student-friendly-ai-assistant",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build:shared",
    "dev:server": "npm --workspace @leetcode-assistant/server run dev",
    "dev:extension": "npm --workspace @leetcode-assistant/extension run dev",
    "build": "npm run build:shared && npm run build:server && npm run build:extension",
    "build:shared": "npm --workspace @leetcode-assistant/shared run build",
    "build:server": "npm --workspace @leetcode-assistant/server run build",
    "build:extension": "npm --workspace @leetcode-assistant/extension run build",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
